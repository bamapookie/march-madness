# This file contains environment variables for the application. Copy it to .env and fill in the values.

# ─── Database (Railway PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ─── Auth.js v5 ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Apple OAuth ──────────────────────────────────────────────────────────────
# https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=""
# Contents of the .p8 key file (keep the newlines)
APPLE_CLIENT_SECRET=""

# ─── Microsoft OAuth ──────────────────────────────────────────────────────────
# https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
# Use "common" to allow any Microsoft account, or a specific tenant ID
MICROSOFT_TENANT_ID="common"

# ─── Vercel Cron ──────────────────────────────────────────────────────────────
# Used to authenticate /api/cron/* routes. Generate with: openssl rand -base64 32
CRON_SECRET=""

# ─── Admin access ─────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that have admin access.
# These users can trigger manual imports and manage season settings.
# Example: ADMIN_EMAILS="alice@example.com,bob@example.com"
ADMIN_EMAILS=""

